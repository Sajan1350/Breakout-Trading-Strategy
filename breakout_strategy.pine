// =============================================================================
// Breakout Trading Strategy for Micro Futures — 1 Minute Timeframe
// =============================================================================
// Based on "The BreakOut Trading Revolution" by Tomas Nesnidal
// Mr. Breakouts Formula — Adapted for Intraday Scalping (10-30 trades/day)
//
// Formula Components (per the book):
//   1. POI: Rolling N-bar High/Low channel (intraday adaptation)
//   2. Space: POI ± (ATR × FRACT) — volatility-adaptive breakout distance
//   3. Filter: ADX trend strength
//   4. Time Parameter: Configurable session window
//   5. Exits: USD stop-loss + USD profit-target + end-of-day exit
//   6. Entry: Market order when price breaks through the level
//
// Works on: Any Micro futures (MES, MNQ, MYM, M2K, MGC, MCL, etc.)
// Timeframe: 1-minute bars
// =============================================================================

//@version=6
strategy("Mr. Breakouts Formula — Micro Futures 1min",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_order,
     commission_value=0.62,
     slippage=1,
     calc_on_every_tick=false,
     process_orders_on_close=false,
     close_entries_rule="ANY",
     margin_long=2,
     margin_short=2)

// ─────────────────────────────────────────────────────────────
// INPUTS — Optimization Parameters (max 6 per book's rule)
// ─────────────────────────────────────────────────────────────
string grp1 = "═══ BREAKOUT FORMULA ═══"
poiLength       = input.int(20, "POI Lookback (bars)", minval=5, maxval=100, step=5, group=grp1,
                   tooltip="Number of bars for the rolling high/low channel. Lower = more signals. Try 10-30.")
fract           = input.float(0.2, "FRACT (ATR Multiplier)", minval=0.0, step=0.05, group=grp1,
                   tooltip="Extra space beyond the channel via ATR. 0 = pure channel breakout. Try 0.0-0.5")
stopLossUSD     = input.float(30.0, "Stop Loss ($)", minval=5, step=5, group=grp1,
                   tooltip="USD-based stop loss per contract")
profitTargetUSD = input.float(60.0, "Profit Target ($)", minval=5, step=5, group=grp1,
                   tooltip="USD-based profit target per contract")
adxThreshold    = input.float(50.0, "ADX Threshold", minval=10, step=5, group=grp1,
                   tooltip="Enter when ADX < this. Higher = more permissive. 50+ = nearly always on.")
atrLength       = input.int(14, "ATR Period (1-min)", minval=1, group=grp1,
                   tooltip="ATR lookback on 1-min bars for SPACE calculation")

// ─────────────────────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────────────────────
string grp2 = "═══ SETTINGS ═══"
adxLength       = input.int(14, "ADX Period", minval=1, group=grp2)
cooldownBars    = input.int(5, "Cooldown After Trade (bars)", minval=0, maxval=50, group=grp2,
                   tooltip="Wait N bars after exit before next entry. Prevents overtrading.")

// ─────────────────────────────────────────────────────────────
// TIME FILTER
// ─────────────────────────────────────────────────────────────
string grp3 = "═══ TIME FILTER ═══"
useTimeFilter   = input.bool(false, "Enable Time Filter", group=grp3,
                   tooltip="OFF = trade any time. Turn ON and set hours for specific sessions.")
entryStartHour  = input.int(9, "Entry Start Hour", minval=0, maxval=23, group=grp3)
entryStartMin   = input.int(30, "Entry Start Minute", minval=0, maxval=59, group=grp3)
entryEndHour    = input.int(15, "Entry End Hour", minval=0, maxval=23, group=grp3)
entryEndMin     = input.int(0, "Entry End Minute", minval=0, maxval=59, group=grp3)
useEODExit      = input.bool(false, "Enable End-of-Day Exit", group=grp3)
exitHour        = input.int(15, "EOD Exit Hour", minval=0, maxval=23, group=grp3)
exitMin         = input.int(50, "EOD Exit Minute", minval=0, maxval=59, group=grp3)

// ─────────────────────────────────────────────────────────────
// DIRECTION
// ─────────────────────────────────────────────────────────────
string grp4 = "═══ DIRECTION ═══"
tradeLongs      = input.bool(true, "Trade Long", group=grp4)
tradeShorts     = input.bool(true, "Trade Short", group=grp4)

// ─────────────────────────────────────────────────────────────
// VISUALS
// ─────────────────────────────────────────────────────────────
string grp5 = "═══ VISUALS ═══"
showBreakoutLevels = input.bool(true, "Show Breakout Levels", group=grp5)
showChannel        = input.bool(true, "Show POI Channel", group=grp5)

// =============================================================================
// CORE CALCULATIONS
// =============================================================================

// ── POI: Rolling N-bar High/Low Channel ──
// This is the intraday adaptation of the book's POI concept.
// Instead of a single daily reference price, we use a rolling
// channel of the highest high and lowest low over N bars.
poiHigh = ta.highest(high, poiLength)
poiLow  = ta.lowest(low, poiLength)

// ── ATR on 1-min bars for SPACE calculation ──
atrValue = ta.atr(atrLength)

// ── SPACE = ATR × FRACT (additional distance beyond channel) ──
space = fract * atrValue

// ── Breakout Levels = Channel ± Space ──
breakoutLong  = poiHigh + space
breakoutShort = poiLow - space

// ── USD to ticks for exits ──
stopLossTicks     = math.round(stopLossUSD / syminfo.pointvalue / syminfo.mintick)
profitTargetTicks = math.round(profitTargetUSD / syminfo.pointvalue / syminfo.mintick)

// ── ADX Filter on 1-min (trend strength) ──
[dmiPlus, dmiMinus, adxVal] = ta.dmi(adxLength, adxLength)
adxFilter = adxVal < adxThreshold

// ── Time Filter ──
currentTime = hour * 100 + minute
entryStartTime = entryStartHour * 100 + entryStartMin
entryEndTime   = entryEndHour * 100 + entryEndMin
exitTime       = exitHour * 100 + exitMin

inEntryWindow = useTimeFilter ? (currentTime >= entryStartTime and currentTime <= entryEndTime) : true
isSessionClose = useEODExit ? (currentTime >= exitTime) : false

// ── Cooldown tracker ──
var int barsSinceExit = 999
if strategy.position_size == 0 and strategy.position_size[1] != 0
    barsSinceExit := 0
else if strategy.position_size == 0
    barsSinceExit := barsSinceExit + 1

pastCooldown = barsSinceExit >= cooldownBars

// =============================================================================
// ENTRY CONDITIONS
// =============================================================================

isFlat = strategy.position_size == 0
canTrade = isFlat and inEntryWindow and adxFilter and pastCooldown

// ── LONG: price breaks above the upper breakout level ──
longBreak = ta.crossover(close, breakoutLong)
longEntry = canTrade and tradeLongs and longBreak

// ── SHORT: price breaks below the lower breakout level ──
shortBreak = ta.crossunder(close, breakoutShort)
shortEntry = canTrade and tradeShorts and shortBreak

// ── Execute entries ──
if longEntry
    strategy.entry("Long", strategy.long, comment="BO Long")

if shortEntry
    strategy.entry("Short", strategy.short, comment="BO Short")

// =============================================================================
// EXIT CONDITIONS
// =============================================================================

if strategy.position_size > 0
    strategy.exit("Long Exit", "Long",
                  loss=stopLossTicks,
                  profit=profitTargetTicks,
                  comment_loss="SL", comment_profit="PT")

if strategy.position_size < 0
    strategy.exit("Short Exit", "Short",
                  loss=stopLossTicks,
                  profit=profitTargetTicks,
                  comment_loss="SL", comment_profit="PT")

if isSessionClose and strategy.position_size != 0
    strategy.close_all(comment="EOD Exit")

// =============================================================================
// PLOTTING
// =============================================================================

// POI Channel (the N-bar high/low)
pChanHigh = plot(showChannel ? poiHigh : na, "Channel High",
                 color=color.new(color.yellow, 60), linewidth=1, style=plot.style_stepline)
pChanLow  = plot(showChannel ? poiLow : na, "Channel Low",
                 color=color.new(color.yellow, 60), linewidth=1, style=plot.style_stepline)
fill(pChanHigh, pChanLow, color=color.new(color.yellow, 93), title="POI Channel")

// Breakout levels (channel + space)
pLong  = plot(showBreakoutLevels ? breakoutLong : na,
              "BO Long", color=color.new(color.lime, 20), linewidth=2, style=plot.style_stepline)
pShort = plot(showBreakoutLevels ? breakoutShort : na,
              "BO Short", color=color.new(color.red, 20), linewidth=2, style=plot.style_stepline)

// Entry signals
plotshape(longEntry, style=shape.labelup, location=location.belowbar,
          color=color.green, text="BUY", textcolor=color.white, size=size.small, title="Long Signal")
plotshape(shortEntry, style=shape.labeldown, location=location.abovebar,
          color=color.red, text="SELL", textcolor=color.white, size=size.small, title="Short Signal")

// Background
bgcolor(useTimeFilter and inEntryWindow ? color.new(color.blue, 95) : na, title="Entry Window")
bgcolor(isSessionClose ? color.new(color.red, 95) : na, title="EOD Zone")

// =============================================================================
// INFO TABLE
// =============================================================================
var table infoTable = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 80),
                                 border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(infoTable, 0, 0, "Mr. Breakouts Formula", text_color=color.white,
               text_size=size.small, bgcolor=color.new(color.blue, 60))
    table.merge_cells(infoTable, 0, 0, 1, 0)

    table.cell(infoTable, 0, 1, "Channel", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 1, str.tostring(poiLength) + " bars", text_color=color.yellow, text_size=size.tiny)

    table.cell(infoTable, 0, 2, "FRACT / ATR", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 2, str.tostring(fract, "#.##") + " x " + str.tostring(atrValue, "#.##"),
               text_color=color.white, text_size=size.tiny)

    table.cell(infoTable, 0, 3, "BO Long", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 3, str.tostring(breakoutLong, "#.##"), text_color=color.lime, text_size=size.tiny)

    table.cell(infoTable, 0, 4, "BO Short", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 4, str.tostring(breakoutShort, "#.##"), text_color=color.red, text_size=size.tiny)

    table.cell(infoTable, 0, 5, "SL / PT", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 5, "$" + str.tostring(stopLossUSD) + " / $" + str.tostring(profitTargetUSD),
               text_color=color.orange, text_size=size.tiny)

    table.cell(infoTable, 0, 6, "ADX", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 6, str.tostring(adxVal, "#.#") + " < " + str.tostring(adxThreshold),
               text_color=adxFilter ? color.lime : color.red, text_size=size.tiny)

    table.cell(infoTable, 0, 7, "Cooldown", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 7, pastCooldown ? "READY" : str.tostring(cooldownBars - barsSinceExit) + " bars",
               text_color=pastCooldown ? color.lime : color.orange, text_size=size.tiny)

    table.cell(infoTable, 0, 8, "Can Trade", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTable, 1, 8, canTrade ? "YES" : "NO",
               text_color=canTrade ? color.lime : color.red, text_size=size.tiny)

    table.cell(infoTable, 0, 9, "Position", text_color=color.gray, text_size=size.tiny)
    string posText = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    color posCol = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(infoTable, 1, 9, posText, text_color=posCol, text_size=size.tiny)

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(longEntry, title="Long Breakout",
               message="LONG Breakout: {{ticker}} at {{close}}")
alertcondition(shortEntry, title="Short Breakout",
               message="SHORT Breakout: {{ticker}} at {{close}}")
